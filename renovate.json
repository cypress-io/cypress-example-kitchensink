{
  "configMigration": true,
  "extends": [
    "config:recommended"
  ],
  "automerge": true,
  "major": {
    "automerge": false
  },
  "prConcurrentLimit": 3,
  "prHourlyLimit": 2,
  "lockFileMaintenance": {
    "enabled": true
  },
  "separateMinorPatch": true,
  "separateMultipleMajor": true,
  "labels": [
    "type: dependencies",
    "renovate"
  ],
  "packageRules": [
    {
      "matchPackageNames": ["/eslint/", "globals"],
      "groupName": "eslint"
    }
  ]
}
